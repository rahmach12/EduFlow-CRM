# Root-level gitignore for EduFlow CRM monorepo

# ── Node (root level) ─────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Environment (NEVER commit secrets) ───────────────────────────────────────
.env
.env.*
!.env.example
